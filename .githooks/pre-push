#!/bin/bash
# sports-picks-skill pre-push hook
# Blocks direct pushes to main branch

protected="main"

while read local_ref local_sha remote_ref remote_sha; do
    if [[ "$remote_ref" = "refs/heads/$protected" ]]; then
        echo "❌ Direct push to '$protected' blocked. Use a feature branch + PR."
        exit 1
    fi
done

exit 0
